# ─────────────────────────────────────────────────────────────────────────
# amazon-push-service — environment template
#
# Copy to data/.env (preferred, lives on the persistent volume) or to the
# project root .env. NEVER commit a real .env. Secrets should come from the
# ControlTower vault whenever possible (see the CT_* block at the bottom).
# ─────────────────────────────────────────────────────────────────────────

# ── HTTP server ───────────────────────────────────────────────────────────
PORT=7791
# Public URL used to build email approval links — must be reachable from an
# approver's browser (LAN IP / hostname, NOT localhost on a headless box).
PUBLIC_URL=http://localhost:7791
# Comma-separated CORS allow-list (origins). Empty = same-origin only.
CORS_ORIGINS=

# ── Auth ──────────────────────────────────────────────────────────────────
# Machine callers present a bearer token. Format: name:token,name:token
# e.g. flyapp-prod:long-random-token,batch-runner:another-token
PUSH_SERVICE_TOKENS=
# JWT signing secret (>=32 chars). The service signs its OWN operator JWTs
# with this; ListingApp's tokens are never accepted here, and vice-versa.
JWT_SECRET=
# Human operators sign in with their ListingApp account. Credentials are
# verified over the bridge (LISTINGAPP_API_BASE_URL + LISTINGAPP_SERVICE_TOKEN
# below, /api/flyapp-bridge/auth/verify) — password hashes never leave LA.
# The service token used for login/user lookups must be allowed to call the
# bridge's auth/verify + users/:id endpoints.
# Optional break-glass: a static admin token to open the ops UI when the LA
# bridge is unavailable (POST as { "token": "…" } or pass ?token= / x-admin-token).
ADMIN_TOKEN=
# IP throttle on /admin/login (FlyApp-style brute-force guard).
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=20

# ── Write safety ────────────────────────────────────────────────────────────
# Master kill switch. Writes to Amazon are REJECTED (503) unless this is true.
SPAPI_WRITES_ENABLED=false
# Per-scope approval policy: auto | email. Unset scopes default per code
# (CONTENT_MATCH/IMAGES/REVERT=auto, PRICING/VCFIX=email).
APPROVAL_CONTENT_MATCH=auto
APPROVAL_IMAGES=auto
APPROVAL_REVERT=auto
APPROVAL_PRICING=email
APPROVAL_VCFIX=email
# Recipients for the email approval flow (comma-separated).
APPROVERS=
# Minutes an email approval link stays valid.
APPROVAL_TTL_MIN=1440
# 1P-vendor attributes valid on Amazon but absent from the public seller
# LISTING schema (comma-separated). The validator forwards these to Amazon
# instead of dropping/rejecting them. Defaults to `procurement` when unset.
VENDOR_PASSTHROUGH_ATTRS=procurement
# Transient SP-API internal error (code 4000000) retry. Amazon documents this
# generic "internal error — try again" and recommends up to two retries before
# escalating. The forwarder re-submits the SAME patch on a 4000000 result.
# Max number of retries (0 disables) and the backoff (ms) between attempts.
SPAPI_INTERNAL_RETRY_MAX=2
SPAPI_INTERNAL_RETRY_BACKOFF_MS=1000,3000
# Outbound load balancing for SP-API. A client-side token bucket (one per
# region+operation) paces writes/reads so we stay under Amazon's per-operation
# rate limit instead of bursting into HTTP 429s. RATE = steady requests/sec,
# BURST = bucket capacity. Each bucket self-tunes to the live allocation Amazon
# advertises via the x-amzn-RateLimit-Limit header, so these are conservative
# starting points, not hard ceilings.
SPAPI_RATE_LIMIT_ENABLED=true
SPAPI_RATE_LIMIT_RATE=5
SPAPI_RATE_LIMIT_BURST=10
# If Amazon still returns 429 (e.g. a shared pool drained elsewhere), the client
# waits and retries the SAME request in place — honouring a Retry-After header
# when present, else stepping through this backoff (ms). MAX=0 disables it.
SPAPI_RATE_LIMIT_429_RETRY_MAX=3
SPAPI_RATE_LIMIT_429_BACKOFF_MS=1000,2000,5000

# ── Amazon SP-API (LWA) ─────────────────────────────────────────────────────
# Prefer provisioning these in the ControlTower vault under a DEDICATED
# provider for this service (see CT_VAULT_PROVIDERS below) so the push
# service has its own least-privilege credential, separate from FlyApp.
SP_API_LWA_CLIENT_ID=
SP_API_LWA_CLIENT_SECRET=
SP_API_REFRESH_TOKEN=
# Optional region-specific LWA credentials. If any value is set for a region,
# all three values for that region must be set; they are a matched Amazon LWA
# app authorization set and must not be mixed with another region's token.
SP_API_LWA_CLIENT_ID_NA=
SP_API_LWA_CLIENT_SECRET_NA=
SP_API_REFRESH_TOKEN_NA=
SP_API_LWA_CLIENT_ID_EU=
SP_API_LWA_CLIENT_SECRET_EU=
SP_API_REFRESH_TOKEN_EU=
SP_API_LWA_CLIENT_ID_FE=
SP_API_LWA_CLIENT_SECRET_FE=
SP_API_REFRESH_TOKEN_FE=
SP_API_ENDPOINT_NA=https://sellingpartnerapi-na.amazon.com
SP_API_ENDPOINT_EU=https://sellingpartnerapi-eu.amazon.com
SP_API_ENDPOINT_FE=https://sellingpartnerapi-fe.amazon.com
SP_API_USER_AGENT=AmazonPushService/0.1.0 (Language=Node.js)

# ── Source of truth (ListingApp HTTP bridge) ────────────────────────────────
LISTINGAPP_API_BASE_URL=http://10.10.10.52:7777
# Dedicated, read-only service token for this app (issued by ListingApp).
LISTINGAPP_SERVICE_TOKEN=
LISTINGAPP_API_TIMEOUT_MS=90000
# Effective shipping season pinned for pricing reads (matches FlyApp).
EFFECTIVE_PRICING_SEASON_ID=3

# ── Content source adapter ──────────────────────────────────────────────────
# Where listing copy (title/bullets/description) comes from. Options:
#   none  — push PIM/pricing-derived attributes only (content out of scope)
#   http  — read from a JSON endpoint that returns { title, description, bullets[] }
CONTENT_SOURCE=none
# Used when CONTENT_SOURCE=http. {asin}/{marketplace} are substituted.
CONTENT_SOURCE_URL=
CONTENT_SOURCE_TOKEN=

# ── AI error resolver (OpenAI) ──────────────────────────────────────────────
# Powers the "Review & fix (AI)" action on the Errors tab and English error
# translation. Prefer loading the key from ControlTower (see CT_VAULT_PROVIDERS
# below) instead of keeping a plaintext key here. When CT is configured, the
# service fetches `openai.api_key` over HTTPS at boot and on demand.
# The feature stays OFF when OPENAI_RESOLVER_ENABLED=false; otherwise it is ON
# whenever a key is inline or ControlTower credentials (CT_CLIENT_ID/SECRET) are set.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_RESOLVER_ENABLED=true
# Optional override when the CT provider key is not literally `openai`.
CT_OPENAI_VAULT_PROVIDER=openai

# ── SMTP (approval emails) ──────────────────────────────────────────────────
SMTP_SERVER=battatco-com.mail.protection.outlook.com
SMTP_PORT=25
SMTP_FROM=python.notification@battatco.com
EMAIL_SENDER_NAME=Amazon Push Service
SEND_EMAILS=true

# ── ControlTower vault (preferred secret source) ────────────────────────────
# When configured, secrets are hydrated into process.env at boot and refreshed
# every CT_VAULT_REFRESH_MIN minutes. Provision a dedicated provider for this
# service so its SP-API credential is segregated from FlyApp's.
CONTROLTOWER_URL=https://10.10.10.52:9999
# Set to 0 when ControlTower serves HTTPS with a self-signed certificate.
CT_TLS_REJECT_UNAUTHORIZED=0
CT_CLIENT_ID=
CT_CLIENT_SECRET=
CT_APP_NAME=AmazonPushService
# Comma-separated providers. Region-suffixed SP-API providers such as
# amazon_sp_api_na and amazon_sp_api_eu hydrate the matching regional env vars
# when their bundle fields are named lwa_client_id/lwa_client_secret/refresh_token.
# Include `openai` so OPENAI_API_KEY is hydrated for AI fixes and error translation.
# You can also use explicit CT_VAULT_MAPPING entries if provider names differ.
# e.g. amazon_sp_api_na,amazon_sp_api_eu,listingapp_push,openai
CT_VAULT_PROVIDERS=
CT_VAULT_MAPPING=
CT_VAULT_REFRESH_MIN=5

# ── Poller ──────────────────────────────────────────────────────────────────
# Cron for the async feed-status poller (settles IN_PROGRESS feed submissions).
POLLER_CRON=*/2 * * * *
# Boot recovery: mark jobs stuck in pending/running older than N minutes.
JOB_STALE_MINUTES=15
# Abandon (FAIL) a feed submission after this many consecutive status-poll
# errors so an unpollable feed can't be re-polled forever.
POLLER_MAX_FEED_ERRORS=10

# ── Safety ──────────────────────────────────────────────────────────────────
# The service refuses to boot if it finds unit-test fixtures (caller='test') in
# the database — that means tests or a script ran against a real DB. Set true to
# deliberately bypass the guard (never in production).
ALLOW_TEST_ROWS=false

# ── Over-time reconciliation ────────────────────────────────────────────────
# After a write APPLIES, the reconciler re-reads the listing from Amazon at the
# offsets below and confirms the pushed attribute values are still reflected.
RECON_ENABLED=true
# Cron for the reconciler (picks up due checks).
RECON_CRON=*/15 * * * *
# Offsets after APPLIED at which to re-check (duration list: s/m/h/d).
RECON_OFFSETS=1h,24h,7d
# Max read-back attempts before a check is marked ERROR (transient retries).
RECON_MAX_ATTEMPTS=3
# Email an alert when drift is detected. Keep OFF until the comparator is
# calibrated against real Amazon responses (drift still records in audit + UI).
RECON_ALERT_ENABLED=false
RECON_ALERT_EMAIL=
